{
  "name": "secure-exchange-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Malaysia Secure Exchange Platform — Bank H2H, ERP File Security, Regulator/API Exchange",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:contract": "turbo run test:contract",
    "test:e2e": "turbo run test:e2e",
    "test:security": "turbo run test:security",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "db:migrate:dev": "pnpm --filter @sep/db exec prisma migrate dev",
    "db:migrate:prod": "pnpm --filter @sep/db exec prisma migrate deploy",
    "db:migrate:ci": "pnpm --filter @sep/db exec prisma migrate deploy",
    "db:seed": "pnpm --filter @sep/db seed",
    "db:studio": "pnpm --filter @sep/db studio",
    "openapi:generate": "pnpm --filter @sep/control-plane openapi:generate",
    "openapi:validate": "pnpm --filter @sep/control-plane openapi:validate",
    "milestone:m0": "pnpm install && pnpm build && docker compose up -d && sleep 5 && pnpm db:migrate && pnpm test",
    "milestone:m1": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:contract && pnpm openapi:validate",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "audit:security": "pnpm audit --audit-level=high",
    "scan:secrets": "git secrets --scan"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@testcontainers/postgresql": "11.14.0",
    "@testcontainers/redis": "11.14.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "lefthook": "2.1.6",
    "msw": "2.13.4",
    "prettier": "^3.2.0",
    "test-exclude": "7",
    "testcontainers": "11.14.0",
    "turbo": "^2.0.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=5.28.4",
      "tar": ">=7.5.11",
      "picomatch": ">=4.0.4",
      "lodash": ">=4.18.0",
      "@fastify/middie": ">=9.2.0",
      "fastify": ">=5.7.2"
    }
  }
}
