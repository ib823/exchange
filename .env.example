# ════════════════════════════════════════════════════════════════
# Malaysia Secure Exchange Platform — Environment Configuration
# Copy this to .env and fill in values before running locally.
# NEVER commit .env to version control.
# NEVER use these default values in staging or production.
# ════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_ENV=dev
LOG_LEVEL=debug
# Allowed: error | warn | info | debug | trace

# ─── Control Plane ────────────────────────────────────────────
CONTROL_PLANE_PORT=3000
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_API_PREFIX=api

# ─── Data Plane ───────────────────────────────────────────────
DATA_PLANE_PORT=3001
DATA_PLANE_HOST=0.0.0.0

# ─── Operator Console ─────────────────────────────────────────
OPERATOR_CONSOLE_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Database (PostgreSQL 16) ─────────────────────────────────
# DATABASE_URL — migration/owner role. Used ONLY by:
#   prisma migrate dev, prisma migrate deploy, prisma db push, prisma db seed
# This role has full DDL privileges (CREATE, ALTER, DROP).
DATABASE_URL=postgresql://sep:sep@localhost:5432/sep_dev

# RUNTIME_DATABASE_URL — application runtime role. Used by:
#   control-plane, data-plane, and all running application code.
# This role has DML only (SELECT, INSERT, UPDATE, DELETE). No DDL.
# In production this MUST be a different role from DATABASE_URL.
RUNTIME_DATABASE_URL=postgresql://sep_app:sep_app@localhost:5432/sep_dev

# For test environment (isolated DB)
DATABASE_TEST_URL=postgresql://sep:sep@localhost:5433/sep_test
RUNTIME_DATABASE_TEST_URL=postgresql://sep_app:sep_app@localhost:5433/sep_test
# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000

# ─── Redis 7 ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=sep:
# BullMQ queue settings
QUEUE_DEFAULT_MAX_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_DELAY_MS=5000
QUEUE_DEAD_LETTER_TTL_MS=604800000
# 7 days

# ─── Object Storage (MinIO / S3-compatible) ───────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=ap-southeast-1
STORAGE_BUCKET_PAYLOADS=sep-payloads
STORAGE_BUCKET_AUDIT_EXPORTS=sep-audit-exports
STORAGE_FORCE_PATH_STYLE=true
# Set false for AWS S3 in production

# ─── Vault (Secret Management / Key Custody) ──────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_KV_MOUNT=secret
VAULT_TRANSIT_MOUNT=transit
# Namespace for this platform's secrets
VAULT_NAMESPACE=sep/
# In production: use AppRole auth, not root token
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# ─── Authentication ───────────────────────────────────────────
# JWT — minimum 32 chars in production, use cryptographically random value
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_VALUE_MINIMUM_32_CHARS
JWT_EXPIRY=15m
JWT_ISSUER=sep-control-plane

# Refresh tokens
REFRESH_TOKEN_SECRET=CHANGE_THIS_TOO_DIFFERENT_FROM_JWT_SECRET
REFRESH_TOKEN_EXPIRY=7d

# API Key settings
API_KEY_PREFIX=sep_
API_KEY_HASH_ROUNDS=12

# ─── Internal Service Auth (control-plane ↔ data-plane) ───────
INTERNAL_SERVICE_TOKEN=CHANGE_THIS_FOR_SERVICE_TO_SERVICE_AUTH

# ─── Crypto Policy Defaults ───────────────────────────────────
# These are policy defaults — partner profiles may override
CRYPTO_DEFAULT_ALGORITHM=rsa
CRYPTO_DEFAULT_KEY_SIZE=4096
CRYPTO_DEFAULT_HASH=sha256
CRYPTO_DEFAULT_COMPRESSION=zlib
CRYPTO_DEFAULT_OUTPUT_FORMAT=armored
# Allowed: armored | binary

# ─── Key Lifecycle ────────────────────────────────────────────
KEY_EXPIRY_ALERT_DAYS=30
KEY_EXPIRY_CRITICAL_DAYS=7
KEY_ROTATION_OVERLAP_DAYS=7

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX_PER_WINDOW=100
RATE_LIMIT_SUBMISSION_MAX=50

# ─── Webhook Dispatch ─────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=CHANGE_THIS_FOR_WEBHOOK_HMAC_SIGNING
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=5000

# ─── Observability ────────────────────────────────────────────
OTEL_SERVICE_NAME=sep-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_METRICS_PORT=9464

# ─── Audit ────────────────────────────────────────────────────
AUDIT_HASH_SECRET=CHANGE_THIS_FOR_AUDIT_CHAIN_HMAC
# Immutable hash chain key — must never change in production
AUDIT_RETENTION_DAYS=2555
# 7 years default; override per tenant policy

# ─── SFTP Transport ───────────────────────────────────────────
SFTP_CONNECT_TIMEOUT_MS=30000
SFTP_OPERATION_TIMEOUT_MS=60000
SFTP_MAX_RETRY_ATTEMPTS=3
SFTP_RETRY_DELAY_MS=10000

# ─── HTTPS Transport ──────────────────────────────────────────
HTTPS_REQUEST_TIMEOUT_MS=30000
HTTPS_MAX_REDIRECT=0
# Do not follow redirects on financial API calls

# ─── File Handling ────────────────────────────────────────────
MAX_PAYLOAD_SIZE_BYTES=52428800
# 50MB default limit
PAYLOAD_QUARANTINE_ENABLED=true
MALWARE_SCAN_ENABLED=false
# Enable with ClamAV in production: CLAM_AV_HOST=localhost CLAM_AV_PORT=3310

# ─── Feature Flags ────────────────────────────────────────────
FEATURE_DUAL_CONTROL_ENABLED=true
FEATURE_WEBHOOK_ENABLED=true
FEATURE_AUDIT_EXPORT_ENABLED=true
FEATURE_KEY_ROTATION_ENABLED=true
